# ==========================================
# MolCraft Agent 环境变量配置
# 复制此文件为 .env 并填入你的实际密钥
# ==========================================

# ------------------------------------------
# 大语言模型配置（OpenAI 兼容接口）
# ------------------------------------------
# 方案 A：Kimi（Moonshot AI）
# 获取地址：https://platform.moonshot.cn
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_API_KEY=sk-your-moonshot-api-key
LLM_MODEL=kimi-k2.6

# 方案 B：OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o

# 方案 C：阶跃星辰（Stepfun）
# LLM_BASE_URL=https://api.stepfun.com/v1
# LLM_API_KEY=your-stepfun-key
# LLM_MODEL=step-2-16k

# 方案 D：智谱 AI（GLM）
# LLM_BASE_URL=https://api.z.ai/api/paas/v4
# LLM_API_KEY=your-glm-key
# LLM_MODEL=glm-4.6

# 方案 E：DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your-deepseek-key
# LLM_MODEL=deepseek-chat

# 方案 F：本地模型（Ollama / vLLM）
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:14b

# 注：若以上均不配置，系统会尝试读取 ~/.kimi/credentials/kimi-code.json

# ------------------------------------------
# 逆合成 API 配置（可选）
# ------------------------------------------
# IBM RXN for Chemistry
# 获取地址：https://rxn.res.ibm.com/
# 若不配置，将使用内置的简化反应模板
RXN_API_KEY=
# USE_RXN_API=false   # 设为 false 可强制禁用 RXN API
