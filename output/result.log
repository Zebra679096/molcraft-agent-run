   196	def _replace_atom(mol):
   197	    """随机替换一个杂原子或碳原子为另一种原子。"""
   198	    replacements = {6: [7, 8, 9, 16], 7: [6, 8], 8: [6, 7, 16], 16: [6, 8]}
   199	    atoms = [a for a in mol.GetAtoms() if a.GetAtomicNum() in replacements]
   200	    if not atoms:
   201	        return mol
   202	    atom = random.choice(atoms)
   203	    new_atom_num = random.choice(replacements[atom.GetAtomicNum()])
   204	    atom.SetAtomicNum(new_atom_num)
   205	    Chem.SanitizeMol(mol)
   206	    return mol
