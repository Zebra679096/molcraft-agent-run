   505	        current_seeds = docked_batch[:n_seeds]
   506	
   507	        print(
   508	            f"[H002] Gen {gen+1}/{n_generations}: generated {len(batch_mols)}, "
   509	            f"docked {len(docked_batch)}, best {docked_batch[0]['binding_energy'] if docked_batch else 'N/A'}",
   510	            file=sys.stderr,
   511	        )
   512	
   513	    # 全局去重 + 排序
