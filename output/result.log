   270	def _ring_opening(mol):
   271	    """开环反应：打开一个小环。"""
   272	    # 查找小环（3-6元环）
   273	    rings = mol.GetRingInfo()
   274	    ring_atoms = []
   275	    for i in range(rings.NumRings()):
   276	        ring = rings.GetRingAtoms(i)
   277	        if 3 <= len(ring) <= 6:
   278	            ring_atoms.extend(ring)
   279	    
   280	    if not ring_atoms:
   281	        return mol
   282	    
   283	    # 随机选择一个环中的一个原子进行开环
   284	    atom_idx = random.choice(ring_atoms)
   285	    emol = Chem.EditableMol(mol)
   286	    
   287	    # 找到与该原子相连的环键并删除
   288	    atom = mol.GetAtomWithIdx(atom_idx)
   289	    for bond in atom.GetBonds():
   290	        neighbor = bond.GetOtherAtom(atom)
   291	        if neighbor.GetIdx() in ring_atoms:
   292	            # 检查是否是环键
   293	            if bond.IsInRing():
   294	                emol.RemoveBond(atom.GetIdx(), neighbor.GetIdx())
   295	                break
   296	    
   297	    new_mol = emol.GetMol()
   298	    try:
   299	        Chem.SanitizeMol(new_mol)
   300	        return new_mol
   301	    except Exception:
   302	        return mol
