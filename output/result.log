   157	def generate_literature_seeds(
   158	    n_seeds: int = 20,
   159	    summary_path: str = None,
   160	    strategy: str = "diverse",
   161	) -> list[dict]:
   162	    """基于文献知识生成种子分子（RAG冷启动）。
   163	
   164	    策略：
   165	      - "diverse": 从CNS骨架+文献骨架中多样性采样
   166	      - "focused": 围绕特定药效团密集采样
   167	      - "cns": 专注CNS渗透性好的骨架
   168	
   169	    Args:
   170	        n_seeds: 目标种子数量
   171	        summary_path: papers/summary.md 路径
   172	        strategy: 生成策略
   173	
   174	    Returns:
   175	        list[dict]: 种子分子列表，包含 SMILES 和性质评估
   176	    """
   177	    # 合并文献提取骨架 + CNS骨架 + 默认骨架
   178	    all_seeds = []
   179	
   180	    # 1. 文献提取
   181	    literature_seeds = extract_seeds_from_summary(summary_path)
   182	    all_seeds.extend(literature_seeds)
   183	
   184	    # 2. CNS 骨架
   185	    for scaffold in CNS_FAVORABLE_SCAFFOLDS:
   186	        if scaffold not in all_seeds:
   187	            all_seeds.append(scaffold)
   188	
   189	    # 3. 默认骨架（补充多样性）
   190	    for scaffold in SCAFFOLDS:
   191	        if scaffold not in all_seeds:
   192	            all_seeds.append(scaffold)
   193	
   194	    # 去重
   195	    unique_seeds = list(dict.fromkeys(all_seeds))
   196	
   197	    # 验证 + 评估
   198	    validated = []
   199	    for smiles in unique_seeds:
   200	        mol = Chem.MolFromSmiles(smiles)
   201	        if mol is None:
   202	            continue
   203	        canonical = Chem.MolToSmiles(mol, canonical=True)
   204	        props = evaluate_molecule(canonical)
   205	        if props.get("valid"):
   206	            # 放宽过滤：种子只需要基本的合理性
   207	            validated.append({**props, "source": "literature_seed"})
   208	
   209	    # 根据策略排序和采样
   210	    if strategy == "cns":
   211	        # CNS策略：按 TPSA（越低CNS渗透越好）和 QED 排序
   212	        validated.sort(key=lambda x: (x.get("tpsa", 999), -x.get("qed", 0)))
   213	    elif strategy == "focused":
   214	        # 聚焦策略：按药效团匹配度排序（磺酰胺/酰胺优先）
   215	        def pharmacophore_score(m):
   216	            smiles = m.get("smiles", "")
   217	            mol = Chem.MolFromSmiles(smiles)
   218	            if mol is None:
   219	                return 0
   220	            score = 0
   221	            for name, pattern in PHARMACOPHORE_PATTERNS.items():
   222	                patt = Chem.MolFromSmarts(pattern)
   223	                if patt and mol.HasSubstructMatch(patt):
   224	                    score += 1
   225	            return score
   226	        validated.sort(key=lambda x: -pharmacophore_score(x))
   227	    else:
   228	        # 多样性策略：按 QED 降序
   229	        validated.sort(key=lambda x: -x.get("qed", 0))
   230	
   231	    # 取前 n_seeds 个
   232	    result = validated[:n_seeds]
   233	
   234	    # 如果种子不够，用变异扩展
   235	    if len(result) < n_seeds:
   236	        extra_needed = n_seeds - len(result)
   237	        existing_smiles = {m["smiles"] for m in result}
   238	        for seed_info in list(result):
   239	            if extra_needed <= 0:
   240	                break
   241	            seed_smiles = seed_info.get("smiles", "")
   242	            if not seed_smiles:
   243	                continue
   244	            for _ in range(5):  # 每个种子尝试5次变异
   245	                if extra_needed <= 0:
   246	                    break
   247	                new_smiles = random_mutate_smiles(seed_smiles, random.randint(1, 2))
   248	                if new_smiles and new_smiles not in existing_smiles:
   249	                    props = evaluate_molecule(new_smiles)
   250	                    if passes_filters(props, max_sa=6.0):
   251	                        result.append({**props, "source": "mutated_seed"})
   252	                        existing_smiles.add(new_smiles)
   253	                        extra_needed -= 1
   254	
   255	    return result
