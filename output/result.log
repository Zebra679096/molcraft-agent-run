   305	def _fragment_exchange(mol):
   306	    """片段交换：用一个小片段替换分子的一部分。"""
   307	    # 从骨架库中随机选择一个小片段
   308	    small_scaffolds = ["C", "O", "N", "c1ccccc1", "C1CCOC1"]
   309	    fragment = random.choice(small_scaffolds)
   310	    fragment_mol = Chem.MolFromSmiles(fragment)
   311	    if fragment_mol is None:
   312	        return mol
   313	    
   314	    # 在分子中随机选择一个键进行替换
   315	    bonds = [mol.GetBondWithIdx(i) for i in range(mol.GetNumBonds())]
   316	    if not bonds:
   317	        return mol
   318	    
   319	    bond = random.choice(bonds)
   320	    atom1 = bond.GetBeginAtom()
   321	    atom2 = bond.GetEndAtom()
   322	    
   323	    # 删除这个键
   324	    emol = Chem.EditableMol(mol)
   325	    emol.RemoveBond(atom1.GetIdx(), atom2.GetIdx())
   326	    
   327	    # 添加片段
   328	    combo = Chem.CombineMols(emol.GetMol(), fragment_mol)
   329	    new_emol = Chem.EditableMol(combo)
   330	    
   331	    # 连接片段到原来的两个原子
   332	    fragment_idx = combo.GetNumAtoms() - fragment_mol.GetNumAtoms()
   333	    new_emol.AddBond(atom1.GetIdx(), fragment_idx, Chem.BondType.SINGLE)
   334	    new_emol.AddBond(atom2.GetIdx(), fragment_idx + 1, Chem.BondType.SINGLE)
   335	    
   336	    new_mol = new_emol.GetMol()
   337	    try:
   338	        Chem.SanitizeMol(new_mol)
   339	        return new_mol
   340	    except Exception:
   341	        return mol
