   247	def _ring_formation(mol):
   248	    """环化反应：在两个原子之间形成环。"""
   249	    # 查找可以形成环的原子对
   250	    atoms = [a for a in mol.GetAtoms() if a.GetAtomicNum() == 6 and a.GetDegree() < 4]
   251	    if len(atoms) < 2:
   252	        return mol
   253	    
   254	    # 尝试形成3-6元环
   255	    for ring_size in [3, 4, 5, 6]:
   256	        if len(atoms) >= ring_size:
   257	            selected_atoms = random.sample(atoms, ring_size)
   258	            try:
   259	                emol = Chem.EditableMol(mol)
   260	                # 连接第一个和最后一个原子
   261	                emol.AddBond(selected_atoms[0].GetIdx(), selected_atoms[-1].GetIdx(), Chem.BondType.SINGLE)
   262	                new_mol = emol.GetMol()
   263	                Chem.SanitizeMol(new_mol)
   264	                return new_mol
   265	            except Exception:
   266	                continue
   267	    return mol
   268	
