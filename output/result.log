   122	def random_mutate_smiles(smiles: str, n_mutations: int = 1):
   123	    """对 SMILES 字符串应用随机变异。"""
   124	    mol = Chem.MolFromSmiles(smiles)
   125	    if mol is None:
   126	        return None
   127	
   128	    for _ in range(n_mutations):
   129	        mol = _mutate_mol(mol)
   130	        if mol is None:
   131	            return None
   132	
   133	    new_smiles = Chem.MolToSmiles(mol, canonical=True)
   134	    return new_smiles
   135	
