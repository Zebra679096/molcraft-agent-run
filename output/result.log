    76	def passes_filters(props: dict, min_qed=0.3, max_mw=500, min_mw=150, max_logp=5.0, max_sa=6.0):
    77	    """检查分子是否通过基础类药性质过滤。
    78	
    79	    注意: max_sa 默认 6.0，与竞赛硬零分条件一致（SAScore>6 零分）。
    80	    之前版本误用 8.0，现已修正。
    81	    """
    82	    if not props.get("valid"):
    83	        return False
    84	    if props["qed"] < min_qed:
    85	        return False
    86	    if not (min_mw <= props["mw"] <= max_mw):
    87	        return False
    88	    if props["logp"] > max_logp:
    89	        return False
    90	    if props["sa_score"] > max_sa:
    91	        return False
    92	    return True
