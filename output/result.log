    52	def estimate_sa_score(mol):
    53	    """非常粗略的合成可及性估算（0-10，越低越好）。
    54	    基于片段复杂度和环系分析。
    55	    """
    56	    # 统计稠环数量
    57	    ri = mol.GetRingInfo()
    58	    atom_rings = ri.AtomRings()
    59	    n_rings = len(atom_rings)
    60	
    61	    # 螺环中心
    62	    spiro = Chem.rdMolDescriptors.CalcNumSpiroAtoms(mol)
    63	
    64	    # 桥头原子
    65	    bridge = Chem.rdMolDescriptors.CalcNumBridgeheadAtoms(mol)
    66	
    67	    # 手性中心
    68	    stereo = Chem.rdMolDescriptors.CalcNumAtomStereoCenters(mol)
    69	
    70	    # 基础启发式公式
    71	    score = 1.0 + n_rings * 0.5 + spiro * 1.0 + bridge * 1.5 + stereo * 0.5
    72	    score += Descriptors.NumRotatableBonds(mol) * 0.1
    73	    return min(score, 10.0)
