    90	def extract_seeds_from_summary(summary_path: str = None) -> list[str]:
    91	    """从 papers/summary.md 中提取可能的活性骨架信息。
    92	
    93	    解析摘要中的 SMILES 字符串和化学结构描述，
    94	    转化为可用于分子生成的种子 SMILES。
    95	
    96	    Args:
    97	        summary_path: papers/summary.md 的路径
    98	
    99	    Returns:
   100	        list[str]: 提取到的种子 SMILES 列表
   101	    """
   102	    if summary_path is None:
   103	        summary_path = os.path.join(
   104	            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
   105	            "papers", "summary.md"
   106	        )
   107	
   108	    seeds = []
   109	
   110	    if not os.path.exists(summary_path):
   111	        return CNS_FAVORABLE_SCAFFOLDS  # 回退到预定义骨架
   112	
   113	    try:
   114	        with open(summary_path, "r", encoding="utf-8") as f:
   115	            content = f.read()
   116	    except Exception:
   117	        return CNS_FAVORABLE_SCAFFOLDS
   118	
   119	    # 尝试从文本中提取 SMILES（简单启发式）
   120	    # 匹配看起来像 SMILES 的模式
   121	    smiles_pattern = re.compile(
   122	        r'(?:SMILES|smiles|骨架|scaffold|结构|structure|活性分子|active molecule)[：:=]\s*([^\s,，。.；;]+)',
   123	        re.IGNORECASE
   124	    )
   125	    for match in smiles_pattern.finditer(content):
   126	        candidate = match.group(1).strip()
   127	        mol = Chem.MolFromSmiles(candidate)
   128	        if mol is not None:
   129	            canonical = Chem.MolToSmiles(mol, canonical=True)
   130	            props = evaluate_molecule(canonical)
   131	            if passes_filters(props, max_sa=6.0):
   132	                seeds.append(canonical)
   133	
   134	    # 提取文本中直接出现的可能是 SMILES 的字符串
   135	    # SMILES 通常包含 C, c, N, O, S, [, ], (, ), =, # 等字符
   136	    potential_smiles = re.findall(r'\b[cCnNoOsS]\S{5,80}\b', content)
   137	    for candidate in potential_smiles:
   138	        # 过滤明显不是 SMILES 的（包含空格、中文等）
   139	        if any(ord(c) > 127 for c in candidate):
   140	            continue
   141	        if candidate in ('class', 'code', 'config', 'common'):
   142	            continue
   143	        try:
   144	            mol = Chem.MolFromSmiles(candidate)
   145	            if mol is not None:
   146	                canonical = Chem.MolToSmiles(mol, canonical=True)
   147	                if canonical not in seeds:
   148	                    props = evaluate_molecule(canonical)
   149	                    if passes_filters(props, max_sa=6.0):
   150	                        seeds.append(canonical)
   151	        except Exception:
   152	            continue
   153	
   154	    return seeds
   155	
