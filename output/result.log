   433	    核心思想：将分子对接作为适应度函数，嵌入生成循环中。
   434	    每批生成少量分子 → 对接评估 → 选择结合能最优的作为种子 → 变异产生下一代。
   435	    这避免了盲生成大量低质量分子，显著提升计算效率。
   436	
   437	    Args:
   438	        docking_fn: 对接函数，接收 SMILES 字符串，返回 dict 包含 "binding_energy"
   439	        n_molecules: 目标生成分子总数
   440	        batch_size: 每批生成的候选分子数
   441	        n_generations: 进化代数（增加到4）
   442	        top_k: 每代选择 top_k 作为种子
   443	        strategy: 初始生成策略
   444	        scaffold: 可选种子骨架
   445	
   446	    Returns:
   447	        list[dict]: 通过过滤且对接成功的分子信息列表，按结合能排序
   448	    """
   449	    import sys
   450	
   451	    all_evaluated = []  # 所有经过对接评估的分子
   452	    current_seeds = None
   453	
   454	    for gen in range(n_generations):
   455	        batch_mols = []
   456	        attempts = 0
   457	        max_attempts = batch_size * 30
   458	
   459	        if gen == 0:
   460	            # 初始代：用传统策略生成
   461	            seeds = SCAFFOLDS if scaffold is None else [scaffold]
   462	            while len(batch_mols) < batch_size and attempts < max_attempts:
   463	                attempts += 1
   464	                seed = random.choice(seeds)
   465	                n_mut = random.randint(1, 4)
   466	                new_smiles = random_mutate_smiles(seed, n_mut)
   467	                if new_smiles and new_smiles not in {m["smiles"] for m in batch_mols}:
   468	                    props = evaluate_molecule(new_smiles)
   469	                    if passes_filters(props):
   470	                        batch_mols.append(props)
   471	        else:
   472	            # 后续代：从种子变异（使用增强的变异）
   473	            seed_smiles_list = [s["smiles"] for s in current_seeds]
   474	            while len(batch_mols) < batch_size and attempts < max_attempts:
   475	                attempts += 1
   476	                seed_smiles = random.choice(seed_smiles_list)
   477	                n_mut = random.randint(1, 3)  # 后续代变异强度略低，保持稳定性
   478	                new_smiles = random_mutate_smiles(seed_smiles, n_mut)
   479	                if new_smiles and new_smiles not in {m["smiles"] for m in batch_mols}:
   480	                    props = evaluate_molecule(new_smiles)
   481	                    if passes_filters(props):
   482	                        batch_mols.append(props)
   483	
   484	        # 对接评估
   485	        docked_batch = []
