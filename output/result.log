   137	def _mutate_mol(mol):
   138	    """增强的单次变异：添加/替换/删除/环化/开环等操作。"""
   139	    choice = random.random()
   140	    try:
   141	        if choice < 0.25:
   142	            mol = _add_substituent(mol)
   143	        elif choice < 0.5:
   144	            mol = _replace_atom(mol)
   145	        elif choice < 0.65:
   146	            mol = _remove_terminal(mol)
   147	        elif choice < 0.75:
   148	            mol = _insert_linker(mol)
   149	        elif choice < 0.85:
   150	            mol = _ring_formation(mol)
   151	        elif choice < 0.95:
   152	            mol = _ring_opening(mol)
   153	        else:
   154	            mol = _fragment_exchange(mol)
   155	    except Exception:
   156	        return None
   157	    if mol is None:
   158	        return None
   159	    # 返回前验证分子有效性
   160	    try:
   161	        Chem.SanitizeMol(mol)
   162	        # 测试 SMILES 往返
   163	        s = Chem.MolToSmiles(mol, canonical=True)
   164	        m2 = Chem.MolFromSmiles(s)
   165	        if m2 is None:
   166	            return None
   167	    except Exception:
   168	        return None
   169	    return mol
   170	
