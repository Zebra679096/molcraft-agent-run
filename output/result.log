    19	    hbd = Lipinski.NumHDonors(mol)
    20	    hba = Lipinski.NumHAcceptors(mol)
    21	    rotb = Descriptors.NumRotatableBonds(mol)
    22	    rings = Descriptors.RingCount(mol)
    23	    qed = QED.qed(mol)
    24	
    25	    # 合成可及性估算（非常粗略）
    26	    sa = estimate_sa_score(mol)
    27	
    28	    # 类药五规则检查
    29	    lipinski_violations = 0
    30	    if mw > 500: lipinski_violations += 1
    31	    if logp > 5: lipinski_violations += 1
    32	    if hbd > 5: lipinski_violations += 1
    33	    if hba > 10: lipinski_violations += 1
    34	    lipinski_ok = lipinski_violations <= 1  # 允许违反 1 条
    35	
    36	    return {
    37	        "valid": True,
    38	        "smiles": smiles,
    39	        "mw": round(mw, 2),
    40	        "logp": round(logp, 2),
    41	        "tpsa": round(tpsa, 2),
    42	        "hbd": hbd,
    43	        "hba": hba,
    44	        "rotatable_bonds": rotb,
    45	        "rings": rings,
    46	        "qed": round(qed, 3),
    47	        "sa_score": round(sa, 2),
    48	        "lipinski_pass": lipinski_ok,
    49	    }
