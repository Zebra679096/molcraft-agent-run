    43	class TeeLogger:
    44	    """同时输出到终端和文件的日志记录器。"""
    45	
    46	    def __init__(self, log_path: Path):
    47	        self.terminal = sys.stdout
    48	        self.log_file = open(log_path, "w", encoding="utf-8")
    49	
    50	    def write(self, message: str) -> None:
    51	        self.terminal.write(message)
    52	        self.log_file.write(message)
    53	        self.log_file.flush()
    54	
    55	    def flush(self) -> None:
    56	        self.terminal.flush()
    57	        self.log_file.flush()
    58	
    59	    def close(self) -> None:
    60	        self.log_file.close()
