    89	
    90	        elapsed = time.time() - start_time
    91	
    92	        # 时间上限
    93	        if elapsed > max_seconds:
    94	            print(
    95	                f"\n\n[{datetime.now().isoformat()}] 达到最大运行时间 "
    96	                f"({int(max_seconds // 60)} 分钟)，正在退出...",
    97	                flush=True,
    98	            )
    99	            stop_event.set()
   100	            return
   101	
   102	        # 迭代次数上限
   103	        if max_iterations > 0 and not limit_printed:
   104	            current = count_iterations()
   105	            print(
   106	                f"\n[{datetime.now().isoformat()}] 迭代进度: {current}/{max_iterations}",
   107	                flush=True,
   108	            )
   109	            if current >= max_iterations:
   110	                print(
   111	                    f"\n[{datetime.now().isoformat()}] 已达到最大迭代次数 "
   112	                    f"({max_iterations} 次)，60 秒后退出...",
   113	                    flush=True,
   114	                )
   115	                limit_printed = True
   116	                await asyncio.sleep(60)
