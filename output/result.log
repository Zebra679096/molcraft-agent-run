   209	def _remove_terminal(mol):
   210	    """删除一个末端原子。"""
   211	    terminals = [a for a in mol.GetAtoms() if a.GetDegree() == 1 and not a.IsInRing()]
   212	    if not terminals:
   213	        return mol
   214	    atom = random.choice(terminals)
   215	    emol = Chem.EditableMol(mol)
   216	    emol.RemoveAtom(atom.GetIdx())
   217	    new_mol = emol.GetMol()
   218	    Chem.SanitizeMol(new_mol)
   219	    return new_mol
   220	
