   222	def _insert_linker(mol):
   223	    """在两个片段之间插入一个小连接子。"""
   224	    linkers = ["C", "O", "N"]
   225	    linker = random.choice(linkers)
   226	    linker_mol = Chem.MolFromSmiles(linker)
   227	    if linker_mol is None:
   228	        return mol
   229	
   230	    combo = Chem.CombineMols(mol, linker_mol)
   231	    emol = Chem.EditableMol(combo)
   232	    atoms = list(mol.GetAtoms())
   233	    if len(atoms) < 2:
   234	        return mol
   235	    a1, a2 = random.sample(atoms, 2)
   236	    linker_idx = combo.GetNumAtoms() - 1
   237	    emol.AddBond(a1.GetIdx(), linker_idx, Chem.BondType.SINGLE)
   238	    emol.AddBond(a2.GetIdx(), linker_idx, Chem.BondType.SINGLE)
   239	    new_mol = emol.GetMol()
   240	    try:
   241	        Chem.SanitizeMol(new_mol)
   242	    except Exception:
   243	        return mol
   244	    return new_mol
