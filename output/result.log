   278	def plan_synthesis_recursive(smiles: str, max_depth: int = 3, current_depth: int = 0, visited: set = None):
   279	    """递归多步逆合成规划（H003）。
   280	
   281	    对目标分子应用单步逆合成规则，然后对得到的反应物（中间体）
