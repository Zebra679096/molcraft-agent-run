   487	            smiles = mol_info["smiles"]
   488	            try:
   489	                dock_result = docking_fn(smiles)
   490	                if dock_result.get("success"):
   491	                    mol_info["binding_energy"] = dock_result.get("binding_energy")
   492	                    mol_info["docking_success"] = True
   493	                    docked_batch.append(mol_info)
   494	            except Exception:
   495	                continue
   496	
   497	        # 按结合能排序（越低越好）
   498	        docked_batch.sort(key=lambda x: x.get("binding_energy", 999))
   499	
