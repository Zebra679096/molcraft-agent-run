   104	    # 原子数 <= 10 视为简单
   105	    if mol.GetNumAtoms() <= 10:
   106	        return True
   107	    # 匹配常见简单骨架
   108	    for s in _SIMPLE_SCAFFOLDS_SMARTS:
   109	        patt = Chem.MolFromSmarts(s)
   110	        if patt and mol.HasSubstructMatch(patt):
   111	            # 但取代基不能太多
   112	            if mol.GetNumAtoms() <= 15:
   113	                return True
   114	    return False
