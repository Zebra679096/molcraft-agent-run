   293	    if visited is None:
   294	        visited = set()
   295	
   296	    # 防止循环
   297	    if smiles in visited:
   298	        return {"success": True, "route": f"{smiles}>>{smiles}", "steps": 0, "trivial": True}
   299	    visited.add(smiles)
   300	
   301	    # 基础情况 1: 达到最大深度
   302	    if current_depth >= max_depth:
   303	        return {"success": True, "route": f"{smiles}>>{smiles}", "steps": 0, "trivial": True}
   304	
   305	    # 基础情况 2: 分子已经足够简单
   306	    if _is_simple_molecule(smiles):
   307	        return {"success": True, "route": f"{smiles}>>{smiles}", "steps": 0, "trivial": True}
