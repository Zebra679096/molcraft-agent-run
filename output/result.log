    24	def _validate_smiles(smiles: str) -> bool:
    25	    """验证 SMILES 字符串是否有效且可解析。"""
    26	    if not smiles or len(smiles) < 1:
    27	        return False
    28	    # 排除仅包含氢或自由基的无效产物
    29	    if smiles in ('[H]', '[H][H]', 'H', '[Br]', '[Cl]', '[I]', '[F]'):
    30	        return False
    31	    mol = Chem.MolFromSmiles(smiles)
    32	    return mol is not None
    33	
    34	
    35	def _try_route(smiles: str, r1: str, r2: str = None) -> str:
    36	    """尝试构建合成路线，验证所有反应物 SMILES。"""
    37	    if not _validate_smiles(r1):
    38	        return None
    39	    if r2 is not None and not _validate_smiles(r2):
    40	        return None
    41	    if r2:
    42	        return f"{r1}.{r2}>>{smiles}"
    43	    return f"{r1}>>{smiles}"
    44	
