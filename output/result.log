   172	def _add_substituent(mol):
   173	    """在随机碳原子上添加小取代基（F, Cl, OH, NH2, CH3）。"""
   174	    substituents = ["F", "Cl", "[OH]", "[NH2]", "C"]
   175	    subst = random.choice(substituents)
   176	    subst_mol = Chem.MolFromSmiles(subst)
   177	    if subst_mol is None:
   178	        return mol
   179	
   180	    # 查找候选原子（非氢、非末端碳原子）
   181	    atoms = [a for a in mol.GetAtoms() if a.GetAtomicNum() == 6 and a.GetDegree() < 4]
   182	    if not atoms:
   183	        return mol
   184	    atom = random.choice(atoms)
   185	
   186	    # 将取代基连接到分子上
   187	    combo = Chem.CombineMols(mol, subst_mol)
   188	    emol = Chem.EditableMol(combo)
   189	    new_bond_idx = combo.GetNumAtoms() - 1
   190	    emol.AddBond(atom.GetIdx(), new_bond_idx, Chem.BondType.SINGLE)
   191	    new_mol = emol.GetMol()
   192	    Chem.SanitizeMol(new_mol)
   193	    return new_mol
   194	
