    50	def dock_molecule(smiles: str, center=None, size=None, exhaustiveness=None):
    51	    """对单个分子进行对接，返回结合能（kcal/mol）。
    52	
    53	    返回字典包含:
    54	        - binding_energy: 最佳构象能量（负值=越好）
    55	        - poses: 构象能量列表
    56	        - success: 是否成功
    57	        - error: 失败原因
    58	    """
    59	    receptor = prepare_receptor()
    60	    ligand_pdbqt = smiles_to_pdbqt(smiles)
    61	    if ligand_pdbqt is None:
    62	        return {"success": False, "error": "配体准备失败"}
    63	
    64	    if center is None:
    65	        center = DOCKING_CENTER
    66	    if size is None:
    67	        size = DOCKING_SIZE
    68	    if exhaustiveness is None:
    69	        exhaustiveness = DOCKING_EXHAUSTIVENESS
    70	
    71	    try:
    72	        v = Vina(sf_name="vina", seed=42, verbosity=0)
    73	        v.set_receptor(receptor)
    74	        v.set_ligand_from_file(ligand_pdbqt)
    75	        v.compute_vina_maps(center=center, box_size=size)
    76	        v.dock(exhaustiveness=exhaustiveness, n_poses=5)
    77	        energies = v.energies(n_poses=1)
    78	        best_energy = float(energies[0][0])
    79	
    80	        # 清理临时文件
    81	        if ligand_pdbqt.startswith(tempfile.gettempdir()):
    82	            os.remove(ligand_pdbqt)
    83	
    84	        return {
    85	            "success": True,
    86	            "binding_energy": round(best_energy, 3),
    87	            "poses": energies.tolist(),
    88	        }
    89	    except Exception as e:
    90	        if ligand_pdbqt and ligand_pdbqt.startswith(tempfile.gettempdir()):
    91	            try:
    92	                os.remove(ligand_pdbqt)
    93	            except Exception:
    94	                pass
    95	        return {"success": False, "error": str(e)}
