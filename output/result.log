    82	async def monitor(stop_event: asyncio.Event, max_iterations: int, max_seconds: float):
    83	    """独立协程：每 30 秒检查迭代次数和时间限制。"""
    84	    start_time = time.time()
    85	    limit_printed = False
    86	
    87	    while not stop_event.is_set():
