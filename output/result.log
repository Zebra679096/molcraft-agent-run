    98	def batch_dock(molecules, center=None, size=None):
    99	    """批量对接分子并返回结果。"""
   100	    results = []
   101	    for i, mol_info in enumerate(molecules):
   102	        smiles = mol_info["smiles"]
   103	        print(f"[对接] {i+1}/{len(molecules)}: {smiles[:40]}...")
   104	        result = dock_molecule(smiles, center, size)
   105	        result["smiles"] = smiles
   106	        result.update(mol_info)
   107	        results.append(result)
   108	    return results
