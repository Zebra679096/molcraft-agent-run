    46	def _run_retro_rule(mol, smarts_pattern, retro_smarts, smiles):
    47	    """通用逆合成规则执行函数。
    48	
    49	    Args:
    50	        mol: 目标分子 RDKit Mol 对象
    51	        smarts_pattern: 匹配目标分子的 SMARTS
    52	        retro_smarts: 逆合成反应的 SMARTS
    53	        smiles: 目标分子的 SMILES（用于构建路线）
    54	
    55	    Returns:
    56	        dict 或 None: 成功时返回 {"route": ..., "reactants": [...], "steps": 1}
    57	    """
    58	    patt = Chem.MolFromSmarts(smarts_pattern)
    59	    if patt is None or not mol.HasSubstructMatch(patt):
    60	        return None
    61	    rxn = AllChem.ReactionFromSmarts(retro_smarts)
    62	    if rxn is None:
    63	        return None
    64	    ps = rxn.RunReactants((mol,))
    65	    if not ps:
    66	        return None
    67	
    68	    # 遍历所有可能的产物集，找到第一个产生有效SMILES的
    69	    for product_set in ps:
    70	        if not product_set:
    71	            continue
    72	        if len(product_set) >= 2:
    73	            r1 = Chem.MolToSmiles(product_set[0])
    74	            r2 = Chem.MolToSmiles(product_set[1])
    75	            route = _try_route(smiles, r1, r2)
    76	            reactants = [r1, r2]
    77	        else:
    78	            r1 = Chem.MolToSmiles(product_set[0])
    79	            route = _try_route(smiles, r1)
    80	            reactants = [r1]
    81	
    82	        if route:
    83	            return {"success": True, "route": route, "reactants": reactants, "steps": 1}
    84	
    85	    return None
    86	
