   327	
   328	            # 构建完整路线：先放子路线（非平凡的），再放当前步
   329	            full_parts = []
   330	            for sub in sub_routes:
   331	                if not sub.get("trivial", False):
   332	                    full_parts.append(sub["route"])
   333	            full_parts.append(result["route"])
   334	            full_route = " | ".join(full_parts)
   335	
   336	            total_steps = result["steps"] + sum(s.get("steps", 0) for s in sub_routes)
   337	            is_trivial = all_trivial and len(reactants) == 1 and reactants[0] == smiles
   338	
   339	            return {
   340	                "success": True,
   341	                "route": full_route,
   342	                "steps": total_steps,
   343	                "trivial": is_trivial,
   344	            }
   345	
   346	    # 回退: 用 BRICS 碎片化尝试找断键
