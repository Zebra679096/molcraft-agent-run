    16	def smiles_to_pdbqt(smiles: str, output_path: str = None):
    17	    """使用 RDKit + Meeko 将 SMILES 转换为 PDBQT 文件。"""
    18	    mol = Chem.MolFromSmiles(smiles)
    19	    if mol is None:
    20	        return None
    21	
    22	    mol = Chem.AddHs(mol)
    23	    ret = AllChem.EmbedMolecule(mol, randomSeed=42)
    24	    if ret != 0:
    25	        ret = AllChem.EmbedMolecule(mol, AllChem.ETKDGv3())
    26	    if ret != 0:
    27	        return None
    28	    try:
    29	        AllChem.MMFFOptimizeMolecule(mol, maxIters=200)
    30	    except Exception:
    31	        pass
    32	
    33	    preparator = MoleculePreparation()
    34	    setup_list = preparator.prepare(mol)
    35	    if not setup_list:
    36	        return None
    37	
    38	    pdbqt_string = PDBQTWriterLegacy.write_string(setup_list[0])[0]
    39	
    40	    if output_path is None:
    41	        fd, output_path = tempfile.mkstemp(suffix=".pdbqt")
    42	        os.close(fd)
    43	
    44	    with open(output_path, "w") as f:
    45	        f.write(pdbqt_string)
    46	
    47	    return output_path
